{
  "schema_version": 2,
  "notification_backend": "auto",
  "temporary_seconds": 8,
  "default_profile": "normal",
  "profiles": {
    "normal": {
      "local": "temporary",
      "slack": "delayed"
    },
    "watch": {
      "local": "persistent",
      "slack": "delayed"
    },
    "away": {
      "local": "off",
      "slack": "immediate"
    },
    "quiet": {
      "local": "off",
      "slack": "off"
    }
  },
  "statuses": {
    "complete": {
      "sound": "Glass",
      "slack_after_seconds": 600,
      "local_timeout_seconds": 600
    },
    "attention": {
      "sound": "Ping",
      "slack_after_seconds": 180,
      "local_timeout_seconds": 0
    },
    "error": {
      "sound": "Basso",
      "slack_after_seconds": 180,
      "local_timeout_seconds": 0
    }
  },
  "sources": {
    "codex": {
      "display_name": "Codex"
    },
    "agy": {
      "display_name": "agy"
    }
  }
}
