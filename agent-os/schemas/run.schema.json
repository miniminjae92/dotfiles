{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-os/schemas/run.schema.json",
  "title": "Developer Agent OS Run frontmatter",
  "type": "object",
  "required": [
    "type",
    "status",
    "origin",
    "created",
    "session_id",
    "project",
    "tier",
    "accepted_success"
  ],
  "properties": {
    "type": { "const": "run" },
    "status": { "enum": ["candidate", "active", "verified", "rejected", "archived"] },
    "origin": { "enum": ["user", "agent", "joint", "inferred"] },
    "created": { "type": "string", "format": "date-time" },
    "session_id": { "type": "string", "minLength": 1 },
    "project": { "type": "string", "minLength": 1 },
    "task_type": { "type": ["string", "null"] },
    "mode": { "type": ["string", "null"] },
    "tier": { "enum": ["T0", "T1", "T2"] },
    "accepted_success": { "type": "boolean" },
    "budget_status": { "enum": ["within", "warning", "exceeded", "unknown"] },
    "safety_incident": { "type": "boolean" },
    "model": { "type": ["string", "null"] },
    "reasoning_effort": { "type": ["string", "null"] },
    "billing_mode": { "enum": ["chatgpt_credit", "api_metered", "local_unmetered", "unknown"] },
    "tokens_observed": { "type": ["integer", "null"], "minimum": 0 },
    "token_scope": { "enum": ["session_total", "stop_delta", "manual", "unknown", null] },
    "input_tokens_observed": { "type": ["integer", "null"], "minimum": 0 },
    "cached_input_tokens_observed": { "type": ["integer", "null"], "minimum": 0 },
    "output_tokens_observed": { "type": ["integer", "null"], "minimum": 0 },
    "reasoning_tokens_observed": { "type": ["integer", "null"], "minimum": 0 },
    "credits_used": { "type": ["number", "null"], "minimum": 0 },
    "delegated_agents": { "type": ["integer", "null"], "minimum": 0 },
    "elapsed_minutes": { "type": ["number", "null"], "minimum": 0 },
    "human_review_minutes": { "type": ["number", "null"], "minimum": 0 },
    "understanding_status": { "enum": ["pending", "passed", "needs_review", "not_required", null] }
  },
  "additionalProperties": false
}
