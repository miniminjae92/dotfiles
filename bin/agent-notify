#!/usr/bin/env python3
"""Persistent, provider-neutral notifications for local agent CLIs."""

from __future__ import annotations

import argparse
import fcntl
import getpass
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import urllib.error
import urllib.parse
import urllib.request
import uuid
from contextlib import contextmanager
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any, Callable, Iterator


SCHEMA_VERSION = 4
OSASCRIPT = "/usr/bin/osascript"
OPEN = "/usr/bin/open"
SECURITY = "/usr/bin/security"
KEYCHAIN_SERVICES = {
    "agent": "agent-notify.slack-webhook",
    "usage": "agent-notify.slack-webhook.usage",
}
AGY_ALLOW_STOP = {"decision": "allow"}
HOOK_SOURCES = {"agy", "codex", "codex-hook"}
TERMINAL_APPS = {
    "Apple_Terminal": "Terminal",
    "iTerm.app": "iTerm2",
    "WezTerm": "WezTerm",
}
TERMINAL_BUNDLE_IDS = {
    "Terminal": "com.apple.Terminal",
    "iTerm": "com.googlecode.iterm2",
    "iTerm2": "com.googlecode.iterm2",
    "WezTerm": "com.github.wez.wezterm",
}
LOCAL_DELIVERIES = {"off", "temporary", "persistent"}
SLACK_DELIVERIES = {"off", "delayed", "immediate"}
USAGE = """usage: agent-notify <command>

Agent adapters:
  codex [json]              Codex external notify adapter
  codex-hook                Codex Stop hook adapter (JSON on stdin)
  agy                       agy Stop hook adapter (JSON on stdin)
  event --source NAME ...   Enqueue a normalized event for any agent CLI

Pending events:
  status                    List pending events
  ack <id|--all>            Acknowledge pending events
  open <id>                 Open the recorded terminal/tmux target and acknowledge

Slack escalation:
  slack configure [agent|usage]
                            Prompt for a destination Webhook URL in macOS Keychain
  slack status [agent|usage|all]
                            Show enabled/configured state without the secret
  slack test [agent|usage]  Send one explicit test message
  slack disable             Disable delivery while preserving the Keychain item

Away delivery:
  away once                Send the next agent result to Slack immediately
  away on [--for 2h]       Send results immediately until disabled or expired
  away off                 Return to delayed Slack escalation
  away status              Show the current away-delivery mode

Delivery modes:
  mode set --local <off|temporary|persistent>
           --slack <off|delayed|immediate> [--for 2h]
                            Set any of the 3 x 3 delivery combinations
  mode status              Show active and one-shot delivery modes
  mode --help              Show values and direct-setting examples
  mode next NAME           Apply one named mode to the next result only

Existing named modes:
  mode normal              Temporary local, delayed Slack fallback
  mode watch               Persistent local, delayed Slack fallback
  mode away [--for 2h]     No local alert, immediate Slack
  mode quiet               Local and Slack off

Examples:
  mode set --local persistent --slack off
  mode set --local temporary --slack off
  mode set --local persistent --slack immediate
  mode set --local off --slack immediate
  mode next away           Send only the next result directly to Slack
  test                     Test click-to-focus from the current tmux pane

Diagnostics:
  test                      Send a persistent click-to-focus test notification
"""
MODE_USAGE = """usage: agent-notify mode <set|status|next|name>

Direct setting:
  mode set --local <off|temporary|persistent>
           --slack <off|delayed|immediate> [--for 2h]

Local values:
  off                      Do not show a Mac notification
  temporary                Show it for 8 seconds, then hide it
  persistent               Keep it until an explicit action

Slack values:
  off                      Do not send to Slack
  delayed                  Send after 3/10 minutes if unacknowledged
  immediate                Send as soon as the result arrives

Examples:
  mode set --local persistent --slack off
  mode set --local temporary --slack off
  mode set --local persistent --slack immediate
  mode set --local off --slack immediate

Other commands:
  mode next NAME           Apply one named preset to the next result only
  mode status              Show the active and one-shot modes

Existing named modes:
  normal                   temporary local + delayed Slack
  watch                    persistent local + delayed Slack
  away [--for 2h]          local off + immediate Slack
  quiet                    local off + Slack off
"""
DEFAULT_CONFIG = {
    "schema_version": 2,
    "notification_backend": "auto",
    "temporary_seconds": 8,
    "default_profile": "normal",
    "profiles": {
        "normal": {"local": "temporary", "slack": "delayed"},
        "watch": {"local": "persistent", "slack": "delayed"},
        "away": {"local": "off", "slack": "immediate"},
        "quiet": {"local": "off", "slack": "off"},
    },
    "statuses": {
        "complete": {
            "sound": "Glass",
            "slack_after_seconds": 600,
            "local_timeout_seconds": 600,
        },
        "attention": {
            "sound": "Ping",
            "slack_after_seconds": 180,
            "local_timeout_seconds": 0,
        },
        "error": {
            "sound": "Basso",
            "slack_after_seconds": 180,
            "local_timeout_seconds": 0,
        },
    },
    "sources": {
        "codex": {"display_name": "Codex"},
        "agy": {"display_name": "agy"},
    },
}


def now_utc() -> datetime:
    return datetime.now(timezone.utc)


def isoformat(value: datetime | None = None) -> str:
    return (value or now_utc()).isoformat(timespec="seconds")


def parse_time(value: str) -> datetime:
    return datetime.fromisoformat(value)


def state_root() -> Path:
    configured = os.environ.get("AGENT_NOTIFY_STATE_DIR")
    if configured:
        return Path(configured).expanduser()
    xdg_state = os.environ.get("XDG_STATE_HOME")
    base = Path(xdg_state).expanduser() if xdg_state else Path.home() / ".local/state"
    return base / "agent-notify"


def config_path() -> Path:
    configured = os.environ.get("AGENT_NOTIFY_CONFIG")
    if configured:
        return Path(configured).expanduser()
    return Path.home() / ".config/agent-notify/config.json"


def events_dir() -> Path:
    return state_root() / "events"


def runtime_settings_path() -> Path:
    return state_root() / "settings.json"


def ensure_private_directory(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True, mode=0o700)
    path.chmod(0o700)


def atomic_write_json(path: Path, value: dict[str, Any]) -> None:
    ensure_private_directory(path.parent)
    descriptor, temporary_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temporary_path = Path(temporary_name)
    try:
        os.fchmod(descriptor, 0o600)
        with os.fdopen(descriptor, "w", encoding="utf-8") as file:
            json.dump(value, file, ensure_ascii=False, indent=2, sort_keys=True)
            file.write("\n")
            file.flush()
            os.fsync(file.fileno())
        os.replace(temporary_path, path)
    finally:
        if temporary_path.exists():
            temporary_path.unlink()


def read_json(path: Path, default: dict[str, Any] | None = None) -> dict[str, Any]:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return dict(default or {})
    if not isinstance(value, dict):
        raise ValueError(f"JSON object expected: {path}")
    return value


def load_config() -> dict[str, Any]:
    config = json.loads(json.dumps(DEFAULT_CONFIG))
    configured = read_json(config_path())
    if configured.get("notification_backend") in {"auto", "osascript", "alerter"}:
        config["notification_backend"] = configured["notification_backend"]
    if isinstance(configured.get("temporary_seconds"), int):
        config["temporary_seconds"] = max(1, min(60, configured["temporary_seconds"]))
    if isinstance(configured.get("default_profile"), str):
        config["default_profile"] = configured["default_profile"]
    if isinstance(configured.get("profiles"), dict):
        for name, profile in configured["profiles"].items():
            if (
                isinstance(name, str)
                and isinstance(profile, dict)
                and profile.get("local") in LOCAL_DELIVERIES
                and profile.get("slack") in SLACK_DELIVERIES
            ):
                config["profiles"][name] = {
                    "local": profile["local"],
                    "slack": profile["slack"],
                }
    if isinstance(configured.get("statuses"), dict):
        for status, settings in configured["statuses"].items():
            if status in config["statuses"] and isinstance(settings, dict):
                config["statuses"][status].update(settings)
    if isinstance(configured.get("sources"), dict):
        config["sources"].update(configured["sources"])
    return config


def runtime_settings() -> dict[str, Any]:
    return read_json(runtime_settings_path(), {"slack_enabled": False})


@contextmanager
def runtime_settings_lock() -> Iterator[None]:
    ensure_private_directory(state_root())
    lock_path = state_root() / ".settings.lock"
    descriptor = os.open(lock_path, os.O_RDWR | os.O_CREAT, 0o600)
    with os.fdopen(descriptor, "r+") as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        yield


def update_runtime_settings(**updates: Any) -> None:
    with runtime_settings_lock():
        settings = runtime_settings()
        settings.update(updates)
        atomic_write_json(runtime_settings_path(), settings)


def event_path(event_id: str) -> Path:
    return events_dir() / f"{event_id}.json"


@contextmanager
def event_lock(event_id: str) -> Iterator[None]:
    ensure_private_directory(events_dir())
    lock_path = events_dir() / f".{event_id}.lock"
    descriptor = os.open(lock_path, os.O_RDWR | os.O_CREAT, 0o600)
    with os.fdopen(descriptor, "r+") as lock:
        fcntl.flock(lock, fcntl.LOCK_EX)
        yield


def load_event(event_id: str) -> dict[str, Any]:
    return read_json(event_path(event_id))


def update_event(
    event_id: str,
    mutate: Callable[[dict[str, Any]], None] | None = None,
    **updates: Any,
) -> dict[str, Any]:
    with event_lock(event_id):
        event = load_event(event_id)
        if mutate:
            mutate(event)
        event.update(updates)
        atomic_write_json(event_path(event_id), event)
        return event


def list_events() -> list[dict[str, Any]]:
    ensure_private_directory(events_dir())
    events = []
    for path in sorted(events_dir().glob("*.json")):
        try:
            events.append(read_json(path))
        except (OSError, ValueError, json.JSONDecodeError):
            continue
    return events


def is_pending(event: dict[str, Any]) -> bool:
    return not any(
        event.get(field)
        for field in ("acknowledged_at", "superseded_at")
    )


def safe_source(value: str) -> str:
    source = value.strip()
    if not source or len(source) > 64:
        raise ValueError("source must contain 1-64 characters")
    if any(character.isspace() or ord(character) < 32 for character in source):
        raise ValueError("source must not contain whitespace or control characters")
    return source


def one_line(value: Any, limit: int) -> str:
    return " ".join(str(value).split())[:limit]


def project_from_payload(payload: dict[str, Any]) -> tuple[str, str | None]:
    cwd = payload.get("cwd")
    if not isinstance(cwd, str):
        workspace_paths = payload.get("workspacePaths")
        if isinstance(workspace_paths, list) and workspace_paths:
            cwd = workspace_paths[0]
    if not isinstance(cwd, str) or not cwd:
        return "현재 프로젝트", None
    return Path(cwd).name or cwd, cwd


def session_from_payload(payload: dict[str, Any]) -> str | None:
    for field in ("session_id", "thread-id", "conversationId", "conversation_id"):
        value = payload.get(field)
        if isinstance(value, str) and value:
            return value
    return None


def tmux_target() -> str | None:
    pane = os.environ.get("TMUX_PANE")
    tmux = tmux_executable()
    if not pane or not tmux:
        return None
    result = subprocess.run(
        [tmux, "display-message", "-p", "-t", pane, "#{session_name}:#{window_index}.#{pane_index}"],
        capture_output=True,
        text=True,
        timeout=2,
        check=False,
    )
    target = result.stdout.strip()
    return target if result.returncode == 0 and target else None


def normalize_event(
    source: str,
    status: str,
    payload: dict[str, Any],
    *,
    label: str | None = None,
) -> dict[str, Any]:
    source = safe_source(source)
    if status not in DEFAULT_CONFIG["statuses"]:
        raise ValueError(f"unsupported status: {status}")
    config = load_config()
    profile = config["statuses"][status]
    source_settings = config["sources"].get(source, {})
    display_name = one_line(label or source_settings.get("display_name") or source, 80)
    project, cwd = project_from_payload(payload)
    session_id = session_from_payload(payload)
    identity = session_id or cwd or project
    dedupe_key = hashlib.sha256(f"{source}\0{identity}".encode()).hexdigest()[:24]
    recorded_tmux_target = tmux_target()
    recorded_tmux_session = None
    if recorded_tmux_target and ":" in recorded_tmux_target:
        recorded_tmux_session = recorded_tmux_target.rsplit(":", 1)[0]
    terminal_app = TERMINAL_APPS.get(os.environ.get("TERM_PROGRAM", ""), "iTerm2")
    return {
        "schema_version": SCHEMA_VERSION,
        "id": str(uuid.uuid4()),
        "source": source,
        "source_label": display_name,
        "status": status,
        "project": one_line(project, 160),
        "cwd": cwd,
        "session_id": session_id,
        "tmux_target": recorded_tmux_target,
        "tmux_session": recorded_tmux_session,
        "tmux_pane": os.environ.get("TMUX_PANE") or None,
        "terminal_app": terminal_app,
        "terminal_bundle_id": TERMINAL_BUNDLE_IDS[terminal_app],
        "created_at": isoformat(),
        "dedupe_key": dedupe_key,
        "sound": str(profile["sound"]),
        "slack_after_seconds": int(profile["slack_after_seconds"]),
        "local_timeout_seconds": int(profile["local_timeout_seconds"]),
        "acknowledged_at": None,
        "escalated_at": None,
        "superseded_at": None,
        "slack_attempts": 0,
        "slack_immediate": False,
        "policy_name": "normal",
        "local_delivery": "temporary",
        "slack_delivery": "delayed",
    }


def event_from_codex(payload: dict[str, Any], *, hook: bool) -> dict[str, Any] | None:
    expected_field = "hook_event_name" if hook else "type"
    expected_value = "Stop" if hook else "agent-turn-complete"
    if payload.get(expected_field) != expected_value:
        return None
    return normalize_event("codex", "complete", payload)


def event_from_agy(payload: dict[str, Any]) -> dict[str, Any]:
    reason = payload.get("terminationReason")
    if reason == "error" or payload.get("error"):
        status = "error"
    elif reason == "max_steps_exceeded":
        status = "attention"
    else:
        status = "complete"
    return normalize_event("agy", status, payload)


def supersede_matching(event: dict[str, Any]) -> None:
    timestamp = isoformat()
    for existing in list_events():
        if (
            existing.get("id") != event["id"]
            and existing.get("dedupe_key") == event["dedupe_key"]
            and is_pending(existing)
        ):
            update_event(existing["id"], superseded_at=timestamp)


def worker_log_path() -> Path:
    ensure_private_directory(state_root())
    return state_root() / "worker.log"


def spawn_worker(event_id: str) -> None:
    script = str(Path(__file__).resolve())
    with worker_log_path().open("ab", buffering=0) as log:
        subprocess.Popen(
            [sys.executable, script, "worker", event_id],
            stdin=subprocess.DEVNULL,
            stdout=log,
            stderr=log,
            start_new_session=True,
            close_fds=True,
        )


def enqueue_event(event: dict[str, Any], policy: dict[str, Any] | None = None) -> str:
    ensure_private_directory(events_dir())
    if policy is None:
        claim_delivery_policy(event)
    else:
        apply_delivery_policy(event, policy)
    supersede_matching(event)
    atomic_write_json(event_path(event["id"]), event)
    spawn_worker(event["id"])
    return event["id"]


def notification_text(event: dict[str, Any]) -> tuple[str, str]:
    attention = event["status"] in {"attention", "error"}
    suffix = "확인 필요" if attention else "작업 완료"
    detail = {
        "complete": "응답을 확인하세요",
        "attention": "작업 상태를 확인하세요",
        "error": "오류로 종료되었습니다",
    }[event["status"]]
    return f"{event['source_label']} {suffix}", f"{event['project']} · {detail}"


def send_osascript(title: str, message: str, sound: str) -> None:
    script = (
        "on run argv\n"
        "display notification (item 2 of argv) with title (item 1 of argv) "
        "sound name (item 3 of argv)\n"
        "end run"
    )
    subprocess.run(
        [OSASCRIPT, "-e", script, title, message, sound],
        check=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.PIPE,
        text=True,
        timeout=5,
    )


def slack_enabled() -> bool:
    return runtime_settings().get("slack_enabled") is True


def local_notification_backend() -> str:
    return str(load_config().get("notification_backend", "auto"))


def named_policy(name: str) -> dict[str, Any]:
    config = load_config()
    profile = config["profiles"].get(name)
    if not isinstance(profile, dict):
        raise ValueError(f"unknown delivery mode: {name}")
    return {
        "name": name,
        "local": profile["local"],
        "slack": profile["slack"],
        "until": None,
    }


def valid_policy(value: Any) -> bool:
    return (
        isinstance(value, dict)
        and isinstance(value.get("name"), str)
        and value.get("local") in LOCAL_DELIVERIES
        and value.get("slack") in SLACK_DELIVERIES
        and (value.get("until") is None or isinstance(value.get("until"), str))
    )


def default_policy() -> dict[str, Any]:
    config = load_config()
    name = str(config.get("default_profile", "normal"))
    try:
        return named_policy(name)
    except ValueError:
        return named_policy("normal")


def policy_expired(policy: dict[str, Any], current_time: datetime) -> bool:
    until = policy.get("until")
    if not isinstance(until, str):
        return False
    try:
        return current_time >= parse_time(until)
    except ValueError:
        return True


def active_policy(
    settings: dict[str, Any], current_time: datetime | None = None
) -> dict[str, Any]:
    current_time = current_time or now_utc()
    policy = settings.get("active_policy")
    if not valid_policy(policy) or policy_expired(policy, current_time):
        return default_policy()
    return dict(policy)


def claim_delivery_policy(event: dict[str, Any], current_time: datetime | None = None) -> None:
    current_time = current_time or now_utc()
    with runtime_settings_lock():
        settings = runtime_settings()
        next_policy = settings.get("next_policy")
        if valid_policy(next_policy):
            policy = dict(next_policy)
            settings["next_policy"] = None
        else:
            policy = active_policy(settings, current_time)
        if policy_expired(policy, current_time):
            policy = default_policy()
        current = active_policy(settings, current_time)
        if settings.get("active_policy") != current:
            settings["active_policy"] = current
        apply_delivery_policy(event, policy)
        atomic_write_json(runtime_settings_path(), settings)


def apply_delivery_policy(event: dict[str, Any], policy: dict[str, Any]) -> None:
    event.update(
        policy_name=policy["name"],
        local_delivery=policy["local"],
        slack_delivery=policy["slack"],
        slack_immediate=policy["slack"] == "immediate",
    )


def parse_away_duration(value: str) -> timedelta:
    match = re.fullmatch(r"([1-9][0-9]*)([mhd])", value)
    if not match:
        raise ValueError("duration must look like 30m, 2h, or 1d")
    amount = int(match.group(1))
    unit = match.group(2)
    duration = {
        "m": timedelta(minutes=amount),
        "h": timedelta(hours=amount),
        "d": timedelta(days=amount),
    }[unit]
    if duration > timedelta(days=30):
        raise ValueError("away duration must not exceed 30 days")
    return duration


def alerter_path() -> str | None:
    if local_notification_backend() == "osascript":
        return None
    executable = shutil.which("alerter")
    if executable:
        return executable
    for candidate in ("/opt/homebrew/bin/alerter", "/usr/local/bin/alerter"):
        if os.access(candidate, os.X_OK):
            return candidate
    return None


def temporary_notification_seconds() -> int:
    return int(load_config().get("temporary_seconds", 8))


def run_alerter(event: dict[str, Any], executable: str) -> str:
    title, message = notification_text(event)
    command = [
        executable,
        "--title",
        title,
        "--message",
        message,
        "--actions",
        "확인,터미널로 이동",
        "--dropdown-label",
        "처리",
        "--close-label",
        "나중에",
        "--sound",
        event["sound"],
        "--group",
        event["dedupe_key"],
    ]
    process_timeout = None
    if event.get("local_delivery", "temporary") == "temporary":
        notification_timeout = temporary_notification_seconds()
        command.extend(["--timeout", str(notification_timeout)])
        process_timeout = notification_timeout + 10
    result = subprocess.run(
        command,
        capture_output=True,
        text=True,
        check=True,
        timeout=process_timeout,
    )
    return result.stdout.strip()


def tmux_executable() -> str | None:
    executable = shutil.which("tmux")
    if executable:
        return executable
    for candidate in ("/opt/homebrew/bin/tmux", "/usr/local/bin/tmux"):
        if os.access(candidate, os.X_OK):
            return candidate
    return None


def event_terminal_bundle_id(event: dict[str, Any]) -> str:
    configured = event.get("terminal_bundle_id")
    if isinstance(configured, str) and configured:
        return configured
    application = str(event.get("terminal_app") or "iTerm2")
    return TERMINAL_BUNDLE_IDS.get(application, "com.googlecode.iterm2")


def open_event_target(event: dict[str, Any]) -> None:
    target = event.get("tmux_target")
    session = event.get("tmux_session")
    tmux = tmux_executable()
    if target and tmux:
        pane = event.get("tmux_pane")
        if pane:
            resolved = subprocess.run(
                [
                    tmux,
                    "display-message",
                    "-p",
                    "-t",
                    pane,
                    "#{session_name}:#{window_index}.#{pane_index}\t#{session_name}",
                ],
                capture_output=True,
                text=True,
                check=False,
                timeout=3,
            )
            dynamic_target, separator, dynamic_session = resolved.stdout.strip().partition("\t")
            if resolved.returncode == 0 and separator:
                target = dynamic_target
                session = dynamic_session
        clients = subprocess.run(
            [tmux, "list-clients", "-F", "#{client_tty}\t#{session_name}"],
            capture_output=True,
            text=True,
            check=False,
            timeout=3,
        )
        subprocess.run([tmux, "select-window", "-t", target], check=False, timeout=3)
        subprocess.run([tmux, "select-pane", "-t", target], check=False, timeout=3)
        if clients.returncode == 0 and session:
            for line in clients.stdout.splitlines():
                tty, separator, client_session = line.partition("\t")
                if separator and client_session == session:
                    subprocess.run(
                        [tmux, "switch-client", "-c", tty, "-t", session],
                        check=False,
                        timeout=3,
                    )
    subprocess.run(
        [OPEN, "-b", event_terminal_bundle_id(event)],
        check=False,
        timeout=3,
    )


def acknowledge_event(event_id: str, *, opened: bool = False) -> None:
    updates: dict[str, Any] = {"acknowledged_at": isoformat()}
    if opened:
        updates["opened_at"] = updates["acknowledged_at"]
    update_event(event_id, **updates)


def remove_notification(event: dict[str, Any]) -> None:
    executable = alerter_path()
    if not executable:
        return
    subprocess.run(
        [executable, "--remove", event["dedupe_key"]],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
        timeout=5,
    )


def handle_alerter_response(event: dict[str, Any], response: str) -> None:
    normalized = response.strip()
    if normalized in {"터미널로 이동", "@CONTENTCLICKED"}:
        open_event_target(event)
        acknowledge_event(event["id"], opened=True)
    elif normalized in {"확인", "@ACTIONCLICKED"}:
        acknowledge_event(event["id"])


def run_worker(event_id: str) -> int:
    event = load_event(event_id)
    if not is_pending(event):
        return 0
    if event.get("slack_immediate") and not event.get("escalated_at"):
        deliver_slack_event(event, now_utc())
        event = load_event(event_id)
    local_delivery = event.get("local_delivery", "temporary")
    if local_delivery == "off":
        update_event(event_id, presented_at=isoformat(), notification_backend="off")
        return 0
    title, message = notification_text(event)
    alerter = alerter_path()
    if alerter:
        try:
            update_event(event_id, presented_at=isoformat(), notification_backend="alerter")
            response = run_alerter(event, alerter)
            handle_alerter_response(event, response)
            return 0
        except (OSError, subprocess.SubprocessError):
            update_event(
                event_id,
                alerter_failed_at=isoformat(),
            )
    try:
        send_osascript(title, message, event["sound"])
        update_event(
            event_id,
            presented_at=isoformat(),
            notification_backend="osascript",
            presentation_degraded=local_delivery == "persistent",
        )
        return 0
    except (OSError, subprocess.SubprocessError):
        update_event(event_id, local_notification_failed_at=isoformat())
        return 1


def keychain_account() -> str:
    return getpass.getuser()


def valid_slack_webhook(value: str) -> bool:
    parsed = urllib.parse.urlparse(value)
    return (
        parsed.scheme == "https"
        and parsed.hostname == "hooks.slack.com"
        and parsed.path.startswith("/services/")
    )


def read_slack_webhook(destination: str = "agent") -> str | None:
    service = KEYCHAIN_SERVICES[destination]
    result = subprocess.run(
        [SECURITY, "find-generic-password", "-a", keychain_account(), "-s", service, "-w"],
        capture_output=True,
        text=True,
        check=False,
        timeout=5,
    )
    if result.returncode != 0:
        return None
    webhook = result.stdout.strip()
    return webhook if valid_slack_webhook(webhook) else None


def configure_slack(destination: str = "agent") -> int:
    service = KEYCHAIN_SERVICES[destination]
    print(f"{destination} Slack Incoming Webhook URL을 Keychain 프롬프트에 붙여넣으세요.")
    result = subprocess.run(
        [
            SECURITY,
            "add-generic-password",
            "-U",
            "-a",
            keychain_account(),
            "-s",
            service,
            "-l",
            f"Agent Notify Slack Webhook ({destination})",
            "-w",
        ],
        check=False,
    )
    if result.returncode != 0:
        print("agent-notify: Keychain 등록에 실패했습니다.", file=sys.stderr)
        return 1
    if read_slack_webhook(destination) is None:
        print("agent-notify: Slack Webhook 형식이 올바르지 않아 활성화하지 않았습니다.", file=sys.stderr)
        return 1
    update_runtime_settings(slack_enabled=True)
    print(f"Slack {destination} 목적지가 활성화되었습니다.")
    return 0


def post_slack(webhook: str, text: str) -> None:
    request = urllib.request.Request(
        webhook,
        data=json.dumps({"text": text}, ensure_ascii=False).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=10) as response:
        if not 200 <= response.status < 300:
            raise urllib.error.HTTPError(
                webhook, response.status, "Slack webhook failed", response.headers, None
            )


def slack_text(event: dict[str, Any], current_time: datetime) -> str:
    status = {"complete": "완료", "attention": "확인 필요", "error": "오류"}[event["status"]]
    if event.get("slack_immediate"):
        return (
            f":bell: *{event['source_label']} 작업 알림*\n"
            f"• 프로젝트: {event['project']}\n"
            f"• 상태: {status}"
        )
    elapsed = max(0, int((current_time - parse_time(event["created_at"])).total_seconds() // 60))
    return (
        f":hourglass_flowing_sand: *{event['source_label']} 작업 미확인*\n"
        f"• 프로젝트: {event['project']}\n"
        f"• 상태: {status}\n"
        f"• 미확인: {elapsed}분"
    )


def deliver_slack_event(event: dict[str, Any], current_time: datetime, webhook: str | None = None) -> bool:
    if (
        not slack_enabled()
        or event.get("slack_delivery", "delayed") == "off"
        or not is_pending(event)
        or event.get("escalated_at")
    ):
        return False
    attempts = int(event.get("slack_attempts", 0))
    if attempts >= 3:
        return False
    destination = event.get("slack_destination", "agent")
    webhook = webhook or read_slack_webhook(destination)
    if webhook is None:
        print("agent-notify: Slack은 활성화됐지만 Keychain Webhook을 읽지 못했습니다.", file=sys.stderr)
        return False
    try:
        post_slack(webhook, slack_text(event, current_time))
    except (OSError, urllib.error.URLError, urllib.error.HTTPError):
        update_event(
            event["id"],
            slack_attempts=attempts + 1,
            slack_last_failed_at=isoformat(current_time),
        )
        return False
    update_event(
        event["id"],
        slack_attempts=attempts + 1,
        escalated_at=isoformat(current_time),
    )
    return True


def sweep(current_time: datetime | None = None) -> int:
    if not slack_enabled():
        return 0
    current_time = current_time or now_utc()
    failures = 0
    for event in list_events():
        if not is_pending(event) or event.get("escalated_at"):
            continue
        slack_delivery = event.get("slack_delivery", "delayed")
        if slack_delivery == "off":
            continue
        attempts = int(event.get("slack_attempts", 0))
        if attempts >= 3:
            continue
        delay = 0 if slack_delivery == "immediate" else int(event["slack_after_seconds"])
        due_at = parse_time(event["created_at"]) + timedelta(seconds=delay)
        if current_time < due_at:
            continue
        if not deliver_slack_event(event, current_time):
            failures += 1
    return 1 if failures else 0


def print_status() -> int:
    pending = [event for event in list_events() if is_pending(event)]
    if not pending:
        print("pending 알림이 없습니다.")
    for event in pending:
        marker = "slack" if event.get("escalated_at") else "local"
        print(
            f"{event['id'][:8]}  {event['source']:<12} {event['status']:<9} "
            f"{marker:<5}  {event['project']}"
        )
    return 0


def ack_command(identifier: str) -> int:
    matched = 0
    for event in list_events():
        if is_pending(event) and (identifier == "--all" or event["id"].startswith(identifier)):
            remove_notification(event)
            acknowledge_event(event["id"])
            matched += 1
    if matched == 0:
        print("agent-notify: 일치하는 pending 알림이 없습니다.", file=sys.stderr)
        return 1
    print(f"{matched}개 알림을 확인 처리했습니다.")
    return 0


def open_command(identifier: str) -> int:
    matches = [
        event for event in list_events() if is_pending(event) and event["id"].startswith(identifier)
    ]
    if len(matches) != 1:
        print("agent-notify: 하나의 pending 알림 ID를 지정하세요.", file=sys.stderr)
        return 1
    remove_notification(matches[0])
    open_event_target(matches[0])
    acknowledge_event(matches[0]["id"], opened=True)
    return 0


def generic_event(arguments: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="agent-notify event")
    parser.add_argument("--source", required=True)
    parser.add_argument("--label")
    parser.add_argument("--status", choices=["complete", "attention", "error"], default="complete")
    parser.add_argument("--project")
    parser.add_argument("--cwd")
    parser.add_argument("--session")
    parser.add_argument("--local", choices=sorted(LOCAL_DELIVERIES))
    parser.add_argument("--slack", choices=sorted(SLACK_DELIVERIES))
    parser.add_argument("--slack-destination", choices=sorted(KEYCHAIN_SERVICES), default="agent")
    args = parser.parse_args(arguments)
    if (args.local is None) != (args.slack is None):
        raise ValueError("--local과 --slack은 함께 지정해야 합니다")
    cwd = args.cwd
    if not cwd and args.project:
        cwd = args.project
    payload = {"cwd": cwd, "session_id": args.session}
    event = normalize_event(args.source, args.status, payload, label=args.label)
    if args.project:
        event["project"] = one_line(args.project, 500)
    event["slack_destination"] = args.slack_destination
    policy = None
    if args.local is not None and args.slack is not None:
        policy = {
            "name": "event",
            "local": args.local,
            "slack": args.slack,
            "until": None,
        }
    enqueue_event(event, policy)
    return 0


def local_test_command() -> int:
    if alerter_path() is None:
        print(
            "agent-notify: 클릭 가능한 테스트에는 `brew install vjeantet/tap/alerter`가 필요합니다.",
            file=sys.stderr,
        )
        send_osascript(
            "에이전트 알림 테스트",
            "임시 AppleScript fallback 알림입니다",
            "Glass",
        )
        return 1
    event = normalize_event(
        "agent-notify",
        "complete",
        {"cwd": os.getcwd(), "session_id": f"test-{uuid.uuid4()}"},
        label="Agent Notify",
    )
    event["project"] = "클릭하면 기록된 tmux pane으로 이동합니다"
    enqueue_event(
        event,
        {"name": "test", "local": "persistent", "slack": "off", "until": None},
    )
    print("클릭 가능한 지속형 테스트 알림을 전송했습니다.")
    return 0


def slack_command(arguments: list[str]) -> int:
    command = arguments[0] if arguments else "status"
    destination = arguments[1] if len(arguments) > 1 else "agent"
    if destination not in {*KEYCHAIN_SERVICES, "all"}:
        print("usage: agent-notify slack <configure|status|test> [agent|usage]", file=sys.stderr)
        return 2
    if command == "configure":
        if destination == "all":
            return 2
        return configure_slack(destination)
    if command == "disable":
        update_runtime_settings(slack_enabled=False)
        print("Slack 에스컬레이션을 비활성화했습니다. Keychain 항목은 보존했습니다.")
        return 0
    if command == "status":
        destinations = KEYCHAIN_SERVICES if destination == "all" else (destination,)
        for name in destinations:
            configured = read_slack_webhook(name) is not None
            print(
                f"destination={name} enabled={str(slack_enabled()).lower()} "
                f"configured={str(configured).lower()}"
            )
        return 0
    if command == "test":
        if destination == "all":
            return 2
        webhook = read_slack_webhook(destination)
        if webhook is None:
            print("agent-notify: Keychain에 유효한 Webhook이 없습니다.", file=sys.stderr)
            return 1
        post_slack(webhook, f":white_check_mark: Agent Notify Slack 테스트 ({destination})")
        print(f"Slack {destination} 테스트 메시지를 전송했습니다.")
        return 0
    print("usage: agent-notify slack <configure|disable|status|test> [agent|usage]", file=sys.stderr)
    return 2


def policy_with_duration(policy: dict[str, Any], duration: str | None) -> dict[str, Any]:
    result = dict(policy)
    result["until"] = isoformat(now_utc() + parse_away_duration(duration)) if duration else None
    return result


def slack_policy_ready(policy: dict[str, Any]) -> bool:
    if policy["slack"] != "immediate":
        return True
    if slack_enabled() and read_slack_webhook() is not None:
        return True
    print(
        "agent-notify: 즉시 Slack 모드는 먼저 `agent-notify slack configure`가 필요합니다.",
        file=sys.stderr,
    )
    return False


def warn_persistent_backend(policy: dict[str, Any]) -> None:
    if policy["local"] == "persistent" and alerter_path() is None:
        print(
            "agent-notify: persistent 로컬 알림에는 `brew install vjeantet/tap/alerter`가 필요합니다.",
            file=sys.stderr,
        )


def set_active_policy(policy: dict[str, Any]) -> None:
    update_runtime_settings(active_policy=policy, next_policy=None)


def set_next_policy(policy: dict[str, Any]) -> None:
    update_runtime_settings(next_policy=policy)


def print_mode_status() -> int:
    settings = runtime_settings()
    current = active_policy(settings)
    if settings.get("active_policy") != current:
        update_runtime_settings(active_policy=current)
    pending = settings.get("next_policy")
    next_name = pending.get("name") if valid_policy(pending) else "none"
    until = f" until={current['until']}" if current.get("until") else ""
    print(
        f"mode={current['name']} local={current['local']} slack={current['slack']}"
        f"{until} next={next_name}"
    )
    return 0


def mode_command(arguments: list[str]) -> int:
    if not arguments or arguments == ["status"]:
        return print_mode_status()
    if arguments in (["-h"], ["--help"], ["help"]):
        print(MODE_USAGE, end="")
        return 0
    command = arguments[0]
    if command == "next":
        if len(arguments) != 2:
            print(
                "usage: agent-notify mode next "
                "<normal|watch|away|quiet>",
                file=sys.stderr,
            )
            return 2
        policy = named_policy(arguments[1])
        if not slack_policy_ready(policy):
            return 1
        warn_persistent_backend(policy)
        set_next_policy(policy)
        print(f"다음 에이전트 결과 한 건에 {policy['name']} 모드를 적용합니다.")
        return 0
    if command == "set":
        parser = argparse.ArgumentParser(prog="agent-notify mode set")
        parser.add_argument("--local", choices=sorted(LOCAL_DELIVERIES), required=True)
        parser.add_argument("--slack", choices=sorted(SLACK_DELIVERIES), required=True)
        parser.add_argument("--for", dest="duration")
        args = parser.parse_args(arguments[1:])
        policy = policy_with_duration(
            {"name": "custom", "local": args.local, "slack": args.slack},
            args.duration,
        )
    else:
        parser = argparse.ArgumentParser(prog=f"agent-notify mode {command}")
        parser.add_argument("--for", dest="duration")
        args = parser.parse_args(arguments[1:])
        policy = policy_with_duration(named_policy(command), args.duration)
    if not slack_policy_ready(policy):
        return 1
    warn_persistent_backend(policy)
    set_active_policy(policy)
    until = f" until={policy['until']}" if policy.get("until") else ""
    print(
        f"알림 모드: {policy['name']} local={policy['local']} "
        f"slack={policy['slack']}{until}"
    )
    return 0


def away_command(arguments: list[str]) -> int:
    command = arguments[0] if arguments else "status"
    if command == "off":
        if len(arguments) != 1:
            print("usage: agent-notify away off", file=sys.stderr)
            return 2
        set_active_policy(named_policy("normal"))
        print("외출 즉시 알림을 해제했습니다. normal 모드로 돌아갑니다.")
        return 0
    if command == "status":
        if len(arguments) != 1:
            print("usage: agent-notify away status", file=sys.stderr)
            return 2
        return print_mode_status()
    if command not in {"once", "on"}:
        print("usage: agent-notify away <once|on [--for 2h]|off|status>", file=sys.stderr)
        return 2
    policy = named_policy("away")
    if not slack_policy_ready(policy):
        return 1
    if command == "once":
        if len(arguments) != 1:
            print("usage: agent-notify away once", file=sys.stderr)
            return 2
        set_next_policy(policy)
        print("다음 에이전트 결과 한 건을 Slack으로 즉시 전송합니다.")
        return 0
    parser = argparse.ArgumentParser(prog="agent-notify away on")
    parser.add_argument("--for", dest="duration")
    args = parser.parse_args(arguments[1:])
    policy = policy_with_duration(policy, args.duration)
    set_active_policy(policy)
    if policy["until"]:
        print(f"외출 즉시 알림을 활성화했습니다. 자동 해제: {policy['until']}")
    else:
        print("외출 즉시 알림을 활성화했습니다. `agent-notify away off`로 해제하세요.")
    return 0


def load_payload(source: str, arguments: list[str], stdin: str) -> dict[str, Any]:
    raw = arguments[0] if source == "codex" and arguments else stdin
    if not raw.strip():
        return {}
    payload = json.loads(raw)
    if not isinstance(payload, dict):
        raise ValueError("notification payload must be a JSON object")
    return payload


def emit_agy_result() -> None:
    print(json.dumps(AGY_ALLOW_STOP, separators=(",", ":")))


def hook_command(source: str, arguments: list[str], stdin: str) -> int:
    payload = load_payload(source, arguments, stdin)
    if source == "codex":
        event = event_from_codex(payload, hook=False)
    elif source == "codex-hook":
        event = event_from_codex(payload, hook=True)
    else:
        event = event_from_agy(payload)
    if event is not None:
        enqueue_event(event)
    if source == "agy":
        emit_agy_result()
    return 0


def main(arguments: list[str] | None = None, stdin: str | None = None) -> int:
    arguments = list(sys.argv[1:] if arguments is None else arguments)
    if not arguments:
        print(USAGE, file=sys.stderr, end="")
        return 2
    command = arguments.pop(0)
    try:
        if command in {"-h", "--help", "help"}:
            print(USAGE, end="")
            return 0
        if command in HOOK_SOURCES:
            raw_stdin = sys.stdin.read() if stdin is None and command != "codex" else (stdin or "")
            return hook_command(command, arguments, raw_stdin)
        if command == "event":
            return generic_event(arguments)
        if command == "worker" and len(arguments) == 1:
            return run_worker(arguments[0])
        if command == "sweep":
            return sweep()
        if command == "status":
            return print_status()
        if command == "ack" and len(arguments) == 1:
            return ack_command(arguments[0])
        if command == "open" and len(arguments) == 1:
            return open_command(arguments[0])
        if command == "slack":
            return slack_command(arguments)
        if command == "away":
            return away_command(arguments)
        if command == "mode":
            return mode_command(arguments)
        if command == "test":
            return local_test_command()
        raise ValueError(f"unsupported command: {command}")
    except (json.JSONDecodeError, ValueError, OSError, subprocess.SubprocessError) as error:
        print(f"agent-notify: {error}", file=sys.stderr)
        if command == "agy":
            emit_agy_result()
        return 0 if command in HOOK_SOURCES else 1


if __name__ == "__main__":
    sys.exit(main())
