#!/usr/bin/env ruby
# frozen_string_literal: true

require "date"
require "fileutils"
require "json"
require "time"

ALLOWED_FIELDS = %w[
  session_id
  turn_id
  cwd
  hook_event_name
  model
  permission_mode
  transcript_path
].freeze

TOKEN_FIELDS = %w[
  input_tokens
  cached_input_tokens
  output_tokens
  reasoning_output_tokens
  total_tokens
].freeze

MAX_TRANSCRIPT_SCAN_BYTES = 8 * 1024 * 1024

def state_root
  return ENV["AGENT_OS_STATE_DIR"] unless ENV["AGENT_OS_STATE_DIR"].to_s.empty?

  xdg_state_home = ENV["XDG_STATE_HOME"]
  xdg_state_home = File.expand_path("~/.local/state") if xdg_state_home.to_s.empty?
  File.join(xdg_state_home, "agent-os")
end

def sessions_root
  configured_root = ENV["AGENT_OS_SESSIONS_DIR"]
  configured_root = File.expand_path("~/.codex/sessions") if configured_root.to_s.empty?
  File.realpath(configured_root)
end

def each_recent_line(path)
  File.open(path, "rb") do |file|
    scan_bytes = [file.size, MAX_TRANSCRIPT_SCAN_BYTES].min
    file.seek(-scan_bytes, IO::SEEK_END)
    data = file.read(scan_bytes)

    if scan_bytes < file.size
      _partial_line, data = data.split("\n", 2)
      return if data.nil?
    end

    data.each_line.to_a.reverse_each { |line| yield line }
  end
end

def token_counts(value)
  return unless value.is_a?(Hash)

  TOKEN_FIELDS.to_h do |field|
    count = value[field]
    return unless count.is_a?(Integer) && count >= 0

    [field, count]
  end
end

def transcript_metrics(path, session_id, turn_id)
  return {} if path.to_s.empty?

  root = sessions_root
  real_path = File.realpath(path)
  return {} unless real_path.start_with?("#{root}#{File::SEPARATOR}")
  return {} unless File.basename(real_path).include?(session_id)

  usage = nil
  context = nil

  each_recent_line(real_path) do |line|
    record = JSON.parse(line)
    payload = record["payload"]
    next unless payload.is_a?(Hash)

    if usage.nil? && record["type"] == "event_msg" && payload["type"] == "token_count"
      info = payload["info"]
      if info.is_a?(Hash)
        session_total = token_counts(info["total_token_usage"])
        last_request = token_counts(info["last_token_usage"])
        if session_total && last_request
          usage = {
            "source" => "transcript_token_count",
            "session_total" => session_total,
            "last_request" => last_request,
            "model_context_window" => info["model_context_window"]
          }
        end
      end
    end

    if context.nil? && record["type"] == "turn_context"
      matching_turn = turn_id.to_s.empty? || payload["turn_id"] == turn_id
      if matching_turn
        context = {
          "model" => payload["model"],
          "reasoning_effort" => payload["effort"]
        }
      end
    end

    break if usage && context
  rescue JSON::ParserError
    next
  end

  (context || {}).merge("usage" => usage).compact
rescue SystemCallError => error
  warn "agent-os-capture-event: transcript metrics unavailable: #{error.message}"
  {}
end

def duplicate_latest_event?(path, event)
  return false if event["turn_id"].to_s.empty? || !File.file?(path)

  latest = nil
  each_recent_line(path) do |line|
    latest = JSON.parse(line)
    break
  end

  %w[session_id turn_id hook_event_name].all? do |field|
    latest.is_a?(Hash) && latest[field] == event[field]
  end
rescue JSON::ParserError, SystemCallError
  false
end

begin
  payload = JSON.parse($stdin.read)
  unless payload["hook_event_name"] == "Stop" && !payload["session_id"].to_s.empty?
    warn "agent-os-capture-event: ignored unsupported or incomplete hook event"
    exit 0
  end

  event = payload.select { |key, _value| ALLOWED_FIELDS.include?(key) }
  metrics = transcript_metrics(payload["transcript_path"], payload["session_id"], payload["turn_id"])
  event["model"] ||= metrics["model"]
  event["reasoning_effort"] = metrics["reasoning_effort"] if metrics["reasoning_effort"]
  event["usage"] = metrics["usage"] if metrics["usage"]
  event["schema_version"] = 1
  event["recorded_at"] = Time.now.iso8601

  events_dir = File.join(state_root, "events")
  FileUtils.mkdir_p(events_dir, mode: 0o700)
  File.chmod(0o700, events_dir)

  event_path = File.join(events_dir, "#{Date.today.iso8601}.jsonl")
  File.open(event_path, File::WRONLY | File::APPEND | File::CREAT, 0o600) do |file|
    file.flock(File::LOCK_EX)
    unless duplicate_latest_event?(event_path, event)
      file.puts(JSON.generate(event))
      file.flush
    end
    file.flock(File::LOCK_UN)
  end
  File.chmod(0o600, event_path)
rescue JSON::ParserError => error
  warn "agent-os-capture-event: invalid hook input: #{error.message}"
  exit 0
rescue SystemCallError => error
  warn "agent-os-capture-event: record failed: #{error.message}"
  exit 0
end
