#!/usr/bin/env bash
set -euo pipefail

# Snapshot each vault locally and mirror it to its private Git remote so the
# latest notes are readable on the phone (GitHub mobile app) without exposing a
# public site. Pushes are best-effort: an offline or auth-less run must never
# fail the launchd job, because the local commit already preserves history.
export GIT_TERMINAL_PROMPT=0
export GIT_SSH_COMMAND="ssh -o BatchMode=yes -o ConnectTimeout=10"

vaults=(
  "${YGGDRASIL_VAULT:-$HOME/.obsidian/yggdrasil}"
  "${DEVELOPER_OS_VAULT:-$HOME/.obsidian/mimir}"
)

committed=0
pushed=0
skipped=0
push_failed=0

for vault in "${vaults[@]}"; do
  if ! git -C "$vault" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'agent-os-vault-snapshot: not a Git repository: %s\n' "$vault" >&2
    skipped=$((skipped + 1))
    continue
  fi

  git -C "$vault" add --all

  if ! git -C "$vault" diff --cached --quiet; then
    git -C "$vault" commit -m "docs: vault snapshot $(date '+%Y-%m-%d %H:%M')"
    committed=$((committed + 1))
  fi

  if git -C "$vault" remote get-url origin >/dev/null 2>&1; then
    branch="$(git -C "$vault" symbolic-ref --quiet --short HEAD || echo HEAD)"
    if ! git -C "$vault" push --quiet origin "$branch"; then
      printf 'agent-os-vault-snapshot: push skipped (offline/auth): %s\n' "$vault" >&2
      push_failed=$((push_failed + 1))
    else
      pushed=$((pushed + 1))
    fi
  fi
done

# 구조화 이벤트 1줄 (ops-digest 수집용). 텔레메트리 실패가 잡을 깨뜨리면 안 됨.
ops_event="$(command -v ops-event 2>/dev/null || true)"
if [ -z "$ops_event" ]; then
  ops_event="$HOME/.local/bin/ops-event"
fi
if [ -x "$ops_event" ]; then
  sev=info
  if [ "$push_failed" -gt 0 ]; then
    sev=low
  fi
  "$ops_event" --source vault-snapshot --kind run --severity "$sev" \
    committed="$committed" pushed="$pushed" skipped="$skipped" push_failed="$push_failed" \
    2>/dev/null || true
fi
