#!/usr/bin/env python3
"""Claude Code statusLine command.

Reads the statusline JSON payload from stdin and prints a single line:

    <cwd basename> | <model display name> | ctx <used>% | 5h $<cost> $<rate>/h <remaining>

Every segment is optional: if the underlying field is missing or the
payload itself is malformed, that segment (or the whole line) is simply
omitted instead of raising an error.

The 5h segment comes from `ccusage blocks --active` (API-equivalent cost
of the current 5-hour window). ccusage scans every transcript, so it is
refreshed in a detached background process at most once per TTL and the
statusline only ever reads the cached result.
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

CCUSAGE_CACHE = Path.home() / ".cache" / "claude-statusline" / "ccusage-block.json"
CCUSAGE_TTL_SECONDS = 60


def load_payload() -> dict[str, Any]:
    try:
        raw = sys.stdin.read()
    except Exception:
        return {}
    if not raw.strip():
        return {}
    try:
        payload = json.loads(raw)
    except Exception:
        return {}
    return payload if isinstance(payload, dict) else {}


def cwd_segment(payload: dict[str, Any]) -> str | None:
    workspace = payload.get("workspace")
    cwd = None
    if isinstance(workspace, dict):
        cwd = workspace.get("current_dir")
    if not isinstance(cwd, str) or not cwd:
        cwd = payload.get("cwd")
    if not isinstance(cwd, str) or not cwd:
        return None
    base = os.path.basename(cwd.rstrip("/"))
    return base or cwd


def model_segment(payload: dict[str, Any]) -> str | None:
    model = payload.get("model")
    if not isinstance(model, dict):
        return None
    name = model.get("display_name")
    return name if isinstance(name, str) and name else None


def context_percentage(payload: dict[str, Any]) -> float | None:
    ctx = payload.get("context_window")
    if not isinstance(ctx, dict):
        return None

    used = ctx.get("used_percentage")
    if isinstance(used, (int, float)):
        return float(used)

    # Fallback: derive from raw usage + window size when the
    # pre-calculated percentage isn't present.
    size = ctx.get("context_window_size")
    usage = ctx.get("current_usage")
    if isinstance(size, (int, float)) and size > 0 and isinstance(usage, dict):
        try:
            total = sum(
                float(usage.get(field) or 0)
                for field in (
                    "input_tokens",
                    "cache_creation_input_tokens",
                    "cache_read_input_tokens",
                )
            )
            return (total / float(size)) * 100
        except Exception:
            return None
    return None


def context_segment(payload: dict[str, Any]) -> str | None:
    percentage = context_percentage(payload)
    if percentage is None:
        return None
    try:
        return f"ctx {percentage:.0f}%"
    except Exception:
        return None


def _refresh_ccusage_cache() -> None:
    tmp = CCUSAGE_CACHE.with_suffix(".tmp")
    try:
        # An in-flight refresh leaves a recent tmp file; don't stack another.
        if tmp.exists() and time.time() - tmp.stat().st_mtime < 120:
            return
        CCUSAGE_CACHE.parent.mkdir(parents=True, exist_ok=True)
        cmd = (
            f'npx -y ccusage blocks --active --json > "{tmp}" 2>/dev/null'
            f' && mv "{tmp}" "{CCUSAGE_CACHE}"'
        )
        subprocess.Popen(
            ["/bin/sh", "-c", cmd],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception:
        pass


def _format_minutes(minutes: float) -> str:
    total = max(0, int(minutes))
    hours, mins = divmod(total, 60)
    return f"{hours}h{mins:02d}m" if hours else f"{mins}m"


def ccusage_segment() -> str | None:
    try:
        stale = (
            not CCUSAGE_CACHE.exists()
            or time.time() - CCUSAGE_CACHE.stat().st_mtime > CCUSAGE_TTL_SECONDS
        )
        if stale:
            _refresh_ccusage_cache()
        if not CCUSAGE_CACHE.exists():
            return None

        data = json.loads(CCUSAGE_CACHE.read_text())
        blocks = data.get("blocks") if isinstance(data, dict) else None
        if not isinstance(blocks, list):
            return None
        active = next(
            (b for b in blocks if isinstance(b, dict) and b.get("isActive")), None
        )
        if active is None:
            return None

        parts: list[str] = ["5h"]
        cost = active.get("costUSD")
        if isinstance(cost, (int, float)):
            parts.append(f"${cost:.2f}")

        burn = active.get("burnRate")
        if isinstance(burn, dict):
            per_hour = burn.get("costPerHour")
            if isinstance(per_hour, (int, float)):
                parts.append(f"${per_hour:.1f}/h")

        projection = active.get("projection")
        if isinstance(projection, dict):
            remaining = projection.get("remainingMinutes")
            if isinstance(remaining, (int, float)):
                parts.append(_format_minutes(remaining))

        return " ".join(parts) if len(parts) > 1 else None
    except Exception:
        return None


def main() -> int:
    payload = load_payload()

    segments = [
        segment
        for segment in (
            cwd_segment(payload),
            model_segment(payload),
            context_segment(payload),
            ccusage_segment(),
        )
        if segment
    ]

    print(" | ".join(segments))
    return 0


if __name__ == "__main__":
    sys.exit(main())
