#!/usr/bin/env bash
# dotfiles-doctor – read-only health check for the dotfiles + agent environment.
# Verifies symlinks, required tools, agent CLI state, launchd jobs, and
# registry drift (routing.json vs Codex agent TOMLs vs models.json).
# Never changes state. Exit code: number of FAIL findings (capped at 125).
set -uo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
PASS=0 WARN=0 FAIL=0

ok()   { PASS=$((PASS + 1)); printf '\033[32mPASS\033[0m %s\n' "$1"; }
warn() { WARN=$((WARN + 1)); printf '\033[33mWARN\033[0m %s\n' "$1"; }
bad()  { FAIL=$((FAIL + 1)); printf '\033[31mFAIL\033[0m %s\n' "$1"; }

check_link() {
  local target="$1" expected="$2"
  if [ ! -e "$target" ]; then
    bad "link missing: $target"
  elif [ "$(readlink "$target" 2>/dev/null)" = "$expected" ]; then
    ok "link: $target"
  else
    bad "link drift: $target -> $(readlink "$target" 2>/dev/null || echo '(not a symlink)') (expected $expected)"
  fi
}

echo "== Symlinks =="
check_link "$HOME/.zshrc" "$DOTFILES_DIR/.zshrc"
check_link "$HOME/.tmux.conf" "$DOTFILES_DIR/.tmux.conf"
check_link "$HOME/.config/nvim" "$DOTFILES_DIR/.config/nvim"
check_link "$HOME/.codex/AGENTS.md" "$DOTFILES_DIR/agents/AGENTS.md"
check_link "$HOME/.gemini/GEMINI.md" "$DOTFILES_DIR/agents/AGENTS.md"
check_link "$HOME/.claude/CLAUDE.md" "$DOTFILES_DIR/claude/CLAUDE.md"
check_link "$HOME/.codex/hooks.json" "$DOTFILES_DIR/agent-os/hooks.json"
check_link "$HOME/.gemini/config/hooks.json" "$DOTFILES_DIR/agy/hooks.json"
check_link "$HOME/.config/ai-tools/models.json" "$DOTFILES_DIR/ai-tools/models.json"

echo "== Tools =="
for tool in git nvim tmux eza bat fzf fd rg gh zoxide pyenv lazygit jq yt-dlp alerter python3; do
  if command -v "$tool" >/dev/null 2>&1; then
    ok "tool: $tool"
  else
    bad "tool missing: $tool (brew bundle --file $DOTFILES_DIR/Brewfile)"
  fi
done
command -v ollama >/dev/null 2>&1 && ok "tool: ollama" || warn "tool missing: ollama (optional local model; models.json references it)"

echo "== Agent CLIs =="
for cli in codex agy claude; do
  command -v "$cli" >/dev/null 2>&1 && ok "cli: $cli" || bad "cli missing: $cli"
done
for profile in google naver; do
  auth="$HOME/.codex-accounts/$profile/auth.json"
  if [ -f "$auth" ]; then
    mode="$(stat -f '%Lp' "$auth" 2>/dev/null || stat -c '%a' "$auth" 2>/dev/null)"
    if [ "$mode" = "600" ]; then
      ok "codex auth: $profile"
    else
      bad "codex auth permissions: $auth is mode $mode (expected 600)"
    fi
  else
    warn "codex auth missing: run '${profile:0:1}codex login' once on this machine"
  fi
done
for profile in main sub; do
  if [ -e "$HOME/.gemini-accounts/$profile/google_accounts.json" ]; then
    ok "agy auth: $profile"
  else
    warn "agy auth missing: run '$([ "$profile" = main ] && echo magy || echo sagy)' once and log in"
  fi
done
if [ -f "$HOME/.claude/settings.json" ] && grep -q "claude-hook" "$HOME/.claude/settings.json" 2>/dev/null; then
  ok "claude hooks configured"
else
  bad "claude hooks not configured: run install.sh"
fi

echo "== LaunchAgents =="
for label in com.miniminjae.agent-notify-sweep com.miniminjae.agent-os-vault-snapshot \
             com.miniminjae.codex-account-usage com.miniminjae.personal-ops-security \
             com.miniminjae.personal-ops-weekly; do
  if launchctl print "gui/$(id -u)/$label" >/dev/null 2>&1; then
    ok "launchd: $label"
  else
    warn "launchd not loaded: $label (run install.sh)"
  fi
done

echo "== Scripts contract (D-012) =="
paths_env="$DOTFILES_DIR/agent-os/paths.env"
if [ -r "$paths_env" ] && ! grep -qvE '^(#|$|[A-Z_]+=)' "$paths_env"; then
  ok "paths.env parseable"
else
  bad "paths.env missing or malformed: $paths_env"
fi
registry_diff="$(comm -3 \
  <(ls "$DOTFILES_DIR/bin" | grep -v '^__pycache__$' | sort) \
  <(grep -oE '^\| `[a-z0-9-]+`' "$DOTFILES_DIR/agent-os/scripts.md" 2>/dev/null | tr -d '`| ' | sort))"
if [ -z "$registry_diff" ]; then
  ok "scripts registry matches bin/ ($(ls "$DOTFILES_DIR/bin" | grep -cv '^__pycache__$') scripts)"
else
  bad "scripts registry drift (agent-os/scripts.md vs bin/): $(echo "$registry_diff" | tr '\n' ' ')"
fi
# 하드코딩 vault 경로: 계약(paths.env) 미채택 파일 수 — D-012 목표는 단조 감소
uncontracted="$(grep -rlE --exclude-dir=__pycache__ 'obsidian/(mimir|yggdrasil)' "$DOTFILES_DIR/bin" 2>/dev/null |
  xargs grep -L 'paths\.env' 2>/dev/null | wc -l | tr -d ' ')"
if [ "$uncontracted" = 0 ]; then
  ok "hardcoded vault paths: none outside contract"
else
  warn "hardcoded vault paths in $uncontracted file(s) without paths.env contract (D-012: 손댈 때 이관)"
fi

echo "== Registry drift =="
python3 - "$DOTFILES_DIR" <<'PY'
import json, pathlib, re, sys

root = pathlib.Path(sys.argv[1])
failures = []
routing = json.loads((root / "agents" / "routing.json").read_text())
routing_models = {entry["model"] for entry in routing["models"].values()}

# Codex agent TOMLs must use models declared in routing.json.
for toml_path in sorted((root / ".codex" / "agents").glob("*.toml")):
    match = re.search(r'^model\s*=\s*"([^"]+)"', toml_path.read_text(), re.MULTILINE)
    if match and match.group(1) not in routing_models:
        failures.append(f"{toml_path.name}: model '{match.group(1)}' not in routing.json")

# models.json (script-facing registry) must agree with routing.json.
legacy = json.loads((root / "ai-tools" / "models.json").read_text())
for ref, name in legacy.get("models", {}).items():
    if ref in ("agy_gemini_fast", "ollama_local") and name not in routing_models:
        failures.append(f"models.json {ref}: '{name}' not in routing.json")

if failures:
    for failure in failures:
        print(f"DRIFT {failure}")
    sys.exit(1)
print("registries consistent")
PY
case $? in
  0) ok "registry drift: none" ;;
  *) bad "registry drift detected (see DRIFT lines above)" ;;
esac

echo
printf 'summary: %d pass, %d warn, %d fail\n' "$PASS" "$WARN" "$FAIL"
[ "$FAIL" -gt 125 ] && exit 125
exit "$FAIL"
