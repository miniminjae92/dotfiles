#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "usage" ]; then
  shift
  exec "$(dirname "$0")/codex-account-usage" show naver "$@"
fi

if [ "${1:-}" = "login" ] && [ "${2:-}" != "status" ]; then
  shift
  case "${1:-}" in
    --with-api-key|--with-access-token)
      exec "$(dirname "$0")/codex-account" naver login "$@"
      ;;
  esac
  exec env CODEX_ACCOUNT_COMMAND=ncodex \
    "$(dirname "$0")/codex-account-login" naver "$@"
fi

exec "$(dirname "$0")/codex-account" naver "$@"
