#!/usr/bin/env bash
set -euo pipefail

# sagy – AGY wrapper for secondary account (rkdalswo33@gmail.com)
# Mirrors the codex-account pattern: isolate auth per profile,
# share common config via symlinks.

profile="sub"
account_root="${AGY_ACCOUNT_ROOT:-$HOME/.gemini-accounts}"
account_home="$account_root/$profile"
base_home="${AGY_BASE_HOME:-$HOME/.gemini}"

umask 077
mkdir -p "$account_home"
chmod 700 "$account_root" "$account_home"

# Symlink shared config from the base .gemini directory.
# Auth-related files (google_accounts.json, state.json) are NOT shared
# so each profile keeps its own login session.
for shared_path in \
  settings.json \
  config \
  trustedFolders.json \
  GEMINI.md
do
  source_path="$base_home/$shared_path"
  target_path="$account_home/$shared_path"
  if [ -e "$source_path" ] && [ ! -e "$target_path" ] && [ ! -L "$target_path" ]; then
    ln -s "$source_path" "$target_path"
  fi
done

exec agy --gemini_dir="$account_home" "$@"
